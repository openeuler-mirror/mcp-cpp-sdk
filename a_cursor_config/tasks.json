{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang 生成活动文件",
            "command": "/usr/bin/clang++",
            "args": [
                "-std=c++17",
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "-I${workspaceFolder}/cpp_mcp_sdk/ipc/include",
                "-I${workspaceFolder}/cpp_mcp_sdk/ipc/common",
                "-I${workspaceFolder}/cpp_mcp_sdk/ipc/src",
                "${file}",
                "${workspaceFolder}/cpp_mcp_sdk/ipc/src/pipe_communication.cpp",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-pthread"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: 使用CMake构建",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/cpp_mcp_sdk/ipc/build",
                "--target",
                "pipe_communication_example"
            ],
            "options": {
                "cwd": "${workspaceFolder}/cpp_mcp_sdk/ipc"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "使用CMake构建项目"
        },
        {
            "type": "shell",
            "label": "设置Node.js 22.19.0环境",
            "command": "bash",
            "args": [
                "-c",
                "source ~/.nvm/nvm.sh && nvm use 22.19.0 && echo 'Node.js版本: '$(node --version) && echo 'npm版本: '$(npm --version)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "detail": "设置Node.js 22.19.0环境并检查版本"
        },
        {
            "type": "shell",
            "label": "安装MCP服务器包",
            "command": "bash",
            "args": [
                "-c",
                "source ~/.nvm/nvm.sh && nvm use 22.19.0 && npm install -g @modelcontextprotocol/server-filesystem"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "detail": "安装MCP服务器包"
        },
        {
            "type": "shell",
            "label": "设置Node.js环境并构建",
            "command": "bash",
            "args": [
                "-c",
                "source ~/.nvm/nvm.sh && nvm use 22.19.0 && echo 'Node.js版本: '$(node --version) && echo 'npm版本: '$(npm --version) && cd ${workspaceFolder}/cpp_mcp_sdk/ipc && cmake --build build --target pipe_communication_example"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "detail": "设置Node.js 22.19.0环境并构建项目"
        }
    ],
    "version": "2.0.0"
}